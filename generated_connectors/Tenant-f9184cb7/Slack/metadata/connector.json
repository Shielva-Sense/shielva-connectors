{
  "connector_type": "slack",
  "name": "Slack",
  "display_name": "Slack",
  "provider": "Slack",
  "service": "slack",
  "description": "Sync channels, messages, users, and files from Slack.",
  "version": "1.0.0",
  "auth_type": "api_key",
  "install_fields": [
    {
      "key": "bot_token",
      "label": "Bot Token",
      "type": "password",
      "required": true,
      "placeholder": "xoxb-...",
      "description": "Slack Bot User OAuth Token (xoxb-...). From Slack App \u2192 OAuth & Permissions.",
      "help": "Bot Token."
    },
    {
      "key": "channel_types",
      "label": "Channel Types",
      "type": "string",
      "required": false,
      "description": "Comma-separated channel types to sync: public_channel, private_channel, mpim, im. Default: public_channel",
      "help": "Channel Types."
    }
  ],
  "capabilities": [
    "sync",
    "health_check",
    "list_channels",
    "list_users",
    "get_channel_messages"
  ],
  "category": "messaging",
  "apis": [
    {
      "id": "sync",
      "name": "Sync",
      "description": "Sync messages from public channels.",
      "method": "GET",
      "params": [
        {
          "key": "full",
          "label": "Full",
          "type": "boolean",
          "required": false
        },
        {
          "key": "since",
          "label": "Since",
          "type": "text",
          "required": false
        },
        {
          "key": "kb_id",
          "label": "Kb Id",
          "type": "text",
          "required": false
        }
      ]
    },
    {
      "id": "list_channels",
      "name": "List Channels",
      "description": "List all channels via paginated conversations.list.",
      "method": "GET",
      "params": [
        {
          "key": "types",
          "label": "Types",
          "type": "text",
          "required": false
        }
      ]
    },
    {
      "id": "list_messages",
      "name": "List Messages",
      "description": "List messages in a channel via paginated conversations.history.",
      "method": "GET",
      "params": [
        {
          "key": "channel_id",
          "label": "Channel Id",
          "type": "text",
          "required": true
        },
        {
          "key": "oldest",
          "label": "Oldest",
          "type": "text",
          "required": false
        },
        {
          "key": "limit",
          "label": "Limit",
          "type": "number",
          "required": false
        }
      ]
    },
    {
      "id": "list_users",
      "name": "List Users",
      "description": "List all workspace members via paginated users.list.",
      "method": "GET",
      "params": []
    },
    {
      "id": "get_user",
      "name": "Get User",
      "description": "Fetch a single user by ID via users.info.",
      "method": "GET",
      "params": [
        {
          "key": "user_id",
          "label": "User Id",
          "type": "text",
          "required": true
        }
      ]
    }
  ]
}