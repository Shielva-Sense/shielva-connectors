{
  "connector_type": "stripe_payments",
  "connector_id": "stripe_payments",
  "name": "Stripe Payments",
  "provider": "stripe",
  "service": "stripe_payments",
  "version": "1.0.0",
  "description": "Connects to Stripe Payments to sync events, customers, charges, subscriptions, invoices, and more into the Shielva knowledge base.",
  "auth_type": "api_key",
  "install_fields": [
    {
      "key": "api_key",
      "label": "Secret API Key",
      "type": "password",
      "required": true,
      "placeholder": "sk_live_... or sk_test_...",
      "help": "Your Stripe secret API key. Find it in the Stripe Dashboard under Developers \u2192 API keys."
    }
  ],
  "features": [
    "retry",
    "pagination",
    "circuit_breaker",
    "normalizer",
    "rate_limiting",
    "error_handling"
  ],
  "methods": [
    {
      "id": "install",
      "name": "Install / Authenticate",
      "description": "Validate the API key by calling GET /v1/account and establish the connector.",
      "category": "auth"
    },
    {
      "id": "health_check",
      "name": "Health Check",
      "description": "Ping GET /v1/account and return HEALTHY, DEGRADED, or OFFLINE.",
      "category": "health"
    },
    {
      "id": "sync",
      "name": "Sync Events",
      "description": "Full or incremental sync of Stripe events into the knowledge base.",
      "category": "sync"
    },
    {
      "id": "get_balance",
      "name": "Get Balance",
      "description": "Retrieve the current Stripe account balance.",
      "category": "balance",
      "endpoint": "GET /v1/balance"
    },
    {
      "id": "list_customers",
      "name": "List Customers",
      "description": "Paginated list of Stripe customers with optional filters.",
      "category": "customers",
      "endpoint": "GET /v1/customers"
    },
    {
      "id": "get_customer",
      "name": "Get Customer",
      "description": "Retrieve a single customer by ID.",
      "category": "customers",
      "endpoint": "GET /v1/customers/:id"
    },
    {
      "id": "create_customer",
      "name": "Create Customer",
      "description": "Create a new Stripe customer.",
      "category": "customers",
      "endpoint": "POST /v1/customers"
    },
    {
      "id": "update_customer",
      "name": "Update Customer",
      "description": "Update an existing customer's attributes.",
      "category": "customers",
      "endpoint": "POST /v1/customers/:id"
    },
    {
      "id": "delete_customer",
      "name": "Delete Customer",
      "description": "Permanently delete a Stripe customer.",
      "category": "customers",
      "endpoint": "DELETE /v1/customers/:id"
    },
    {
      "id": "list_charges",
      "name": "List Charges",
      "description": "Paginated list of charges.",
      "category": "charges",
      "endpoint": "GET /v1/charges"
    },
    {
      "id": "get_charge",
      "name": "Get Charge",
      "description": "Retrieve a single charge by ID.",
      "category": "charges",
      "endpoint": "GET /v1/charges/:id"
    },
    {
      "id": "list_payment_intents",
      "name": "List Payment Intents",
      "description": "Paginated list of payment intents.",
      "category": "payment_intents",
      "endpoint": "GET /v1/payment_intents"
    },
    {
      "id": "get_payment_intent",
      "name": "Get Payment Intent",
      "description": "Retrieve a single payment intent by ID.",
      "category": "payment_intents",
      "endpoint": "GET /v1/payment_intents/:id"
    },
    {
      "id": "create_payment_intent",
      "name": "Create Payment Intent",
      "description": "Create a new payment intent with amount and currency.",
      "category": "payment_intents",
      "endpoint": "POST /v1/payment_intents"
    },
    {
      "id": "list_subscriptions",
      "name": "List Subscriptions",
      "description": "Paginated list of subscriptions, optionally filtered by customer.",
      "category": "subscriptions",
      "endpoint": "GET /v1/subscriptions"
    },
    {
      "id": "get_subscription",
      "name": "Get Subscription",
      "description": "Retrieve a single subscription by ID.",
      "category": "subscriptions",
      "endpoint": "GET /v1/subscriptions/:id"
    },
    {
      "id": "cancel_subscription",
      "name": "Cancel Subscription",
      "description": "Cancel a subscription immediately.",
      "category": "subscriptions",
      "endpoint": "DELETE /v1/subscriptions/:id"
    },
    {
      "id": "list_products",
      "name": "List Products",
      "description": "Paginated list of Stripe products.",
      "category": "products",
      "endpoint": "GET /v1/products"
    },
    {
      "id": "list_invoices",
      "name": "List Invoices",
      "description": "Paginated list of invoices.",
      "category": "invoices",
      "endpoint": "GET /v1/invoices"
    },
    {
      "id": "create_refund",
      "name": "Create Refund",
      "description": "Create a full or partial refund for a charge.",
      "category": "refunds",
      "endpoint": "POST /v1/refunds"
    },
    {
      "id": "list_events",
      "name": "List Events",
      "description": "Paginated list of events, filterable by type and date range.",
      "category": "events",
      "endpoint": "GET /v1/events"
    },
    {
      "id": "get_event",
      "name": "Get Event",
      "description": "Retrieve a single event by ID.",
      "category": "events",
      "endpoint": "GET /v1/events/:id"
    },
    {
      "id": "list_webhooks",
      "name": "List Webhook Endpoints",
      "description": "List all registered webhook endpoints.",
      "category": "webhooks",
      "endpoint": "GET /v1/webhook_endpoints"
    },
    {
      "id": "create_webhook",
      "name": "Create Webhook Endpoint",
      "description": "Register a new webhook endpoint with enabled event types.",
      "category": "webhooks",
      "endpoint": "POST /v1/webhook_endpoints"
    },
    {
      "id": "delete_webhook",
      "name": "Delete Webhook Endpoint",
      "description": "Delete a webhook endpoint by ID.",
      "category": "webhooks",
      "endpoint": "DELETE /v1/webhook_endpoints/:id"
    }
  ],
  "categories": [
    "auth",
    "health",
    "sync",
    "balance",
    "customers",
    "charges",
    "payment_intents",
    "subscriptions",
    "products",
    "invoices",
    "refunds",
    "events",
    "webhooks"
  ],
  "apis": [
