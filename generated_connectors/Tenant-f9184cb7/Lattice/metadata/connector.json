{
  "connector_type": "lattice",
  "name": "Lattice",
  "display_name": "Lattice",
  "description": "Connect to Lattice to sync employees, goals/OKRs, and performance reviews into Shielva.",
  "version": "1.0.0",
  "auth_type": "api_key",
  "install_fields": [
    {
      "key": "api_token",
      "label": "API Token",
      "type": "password",
      "required": true,
      "description": "Lattice API token generated from your Lattice account settings.",
      "help": "API Token."
    }
  ],
  "capabilities": [
    "list_users",
    "get_user",
    "list_departments",
    "list_goals",
    "list_reviews",
    "list_feedback",
    "sync"
  ],
  "provider": "Lattice",
  "service": "Lattice",
  "category": "hr",
  "apis": [
    {
      "id": "sync",
      "name": "Sync",
      "description": "Sync Lattice users, goals, and performance reviews into the knowledge base.",
      "method": "GET",
      "params": [
        {
          "key": "full",
          "label": "Full",
          "type": "boolean",
          "required": false
        },
        {
          "key": "since",
          "label": "Since",
          "type": "text",
          "required": false
        },
        {
          "key": "kb_id",
          "label": "Kb Id",
          "type": "text",
          "required": false
        }
      ]
    },
    {
      "id": "list_users",
      "name": "List Users",
      "description": "Return all Lattice users/employees (all pages).",
      "method": "GET",
      "params": []
    },
    {
      "id": "list_goals",
      "name": "List Goals",
      "description": "Return all Lattice goals/OKRs (all pages).",
      "method": "GET",
      "params": []
    },
    {
      "id": "list_reviews",
      "name": "List Reviews",
      "description": "Return all Lattice performance reviews (all pages).",
      "method": "GET",
      "params": []
    },
    {
      "id": "list_feedback",
      "name": "List Feedback",
      "description": "Return all Lattice feedback/praise entries (all pages).",
      "method": "GET",
      "params": []
    },
    {
      "id": "list_departments",
      "name": "List Departments",
      "description": "Return all Lattice departments (all pages).",
      "method": "GET",
      "params": []
    },
    {
      "id": "get_user",
      "name": "Get User",
      "description": "Return a single Lattice user as a ConnectorDocument.",
      "method": "GET",
      "params": [
        {
          "key": "user_id",
          "label": "User Id",
          "type": "number",
          "required": true
        }
      ]
    }
  ]
}