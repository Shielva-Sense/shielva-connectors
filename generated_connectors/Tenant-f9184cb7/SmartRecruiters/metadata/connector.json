{
  "connector_type": "smartrecruiters",
  "name": "SmartRecruiters",
  "display_name": "SmartRecruiters",
  "description": "Connect to SmartRecruiters to sync job postings, candidates, and users into Shielva.",
  "version": "1.0.0",
  "auth_type": "api_key",
  "install_fields": [
    {
      "key": "api_token",
      "label": "API Token (X-SmartToken)",
      "type": "password",
      "required": true,
      "description": "Your SmartRecruiters API token. Found in SmartRecruiters \u2192 Admin \u2192 Apps & Integrations \u2192 API.",
      "help": "API Token (X-SmartToken)."
    }
  ],
  "capabilities": [
    "list_jobs",
    "get_job",
    "list_candidates",
    "get_candidate",
    "list_users",
    "list_departments",
    "sync"
  ],
  "provider": "SmartRecruiters",
  "service": "SmartRecruiters",
  "category": "ats",
  "apis": [
    {
      "id": "sync",
      "name": "Sync",
      "description": "Sync all job postings and candidates from SmartRecruiters.",
      "method": "GET",
      "params": [
        {
          "key": "full",
          "label": "Full",
          "type": "boolean",
          "required": false
        },
        {
          "key": "since",
          "label": "Since",
          "type": "text",
          "required": false
        },
        {
          "key": "kb_id",
          "label": "Kb Id",
          "type": "text",
          "required": false
        }
      ]
    },
    {
      "id": "list_jobs",
      "name": "List Jobs",
      "description": "List job postings (single page, up to 100 results).",
      "method": "GET",
      "params": [
        {
          "key": "status",
          "label": "Status",
          "type": "text",
          "required": false
        }
      ]
    },
    {
      "id": "list_candidates",
      "name": "List Candidates",
      "description": "List candidates (single page, up to 100 results).",
      "method": "GET",
      "params": []
    },
    {
      "id": "get_job",
      "name": "Get Job",
      "description": "Return a single job posting by ID.",
      "method": "GET",
      "params": [
        {
          "key": "job_id",
          "label": "Job Id",
          "type": "text",
          "required": true
        }
      ]
    },
    {
      "id": "get_candidate",
      "name": "Get Candidate",
      "description": "Return a single candidate by ID.",
      "method": "GET",
      "params": [
        {
          "key": "candidate_id",
          "label": "Candidate Id",
          "type": "text",
          "required": true
        }
      ]
    },
    {
      "id": "list_users",
      "name": "List Users",
      "description": "List users (single page, up to 100 results).",
      "method": "GET",
      "params": []
    },
    {
      "id": "list_departments",
      "name": "List Departments",
      "description": "Return all departments.",
      "method": "GET",
      "params": []
    }
  ]
}