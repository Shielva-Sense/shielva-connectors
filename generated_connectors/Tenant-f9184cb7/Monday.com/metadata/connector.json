{
  "connector_type": "monday",
  "name": "Monday.com",
  "display_name": "Monday.com",
  "description": "Connect to Monday.com to sync boards, items, and workspaces via the Monday.com GraphQL API v2.",
  "version": "1.0.0",
  "auth_type": "api_key",
  "install_fields": [
    {
      "key": "api_token",
      "label": "API Token",
      "type": "password",
      "required": true,
      "description": "Monday.com personal API token. Go to Profile \u2192 Developers \u2192 My Access Tokens \u2192 Show to copy it.",
      "help": "API Token."
    }
  ],
  "capabilities": [
    "list_boards",
    "get_board",
    "list_items",
    "get_item",
    "list_workspaces",
    "sync"
  ],
  "provider": "monday",
  "category": "project_management",
  "apis": [
    {
      "id": "sync",
      "name": "Sync",
      "description": "Sync all boards and their items from Monday.com.",
      "method": "GET",
      "params": [
        {
          "key": "full",
          "label": "Full",
          "type": "boolean",
          "required": false
        },
        {
          "key": "since",
          "label": "Since",
          "type": "text",
          "required": false
        },
        {
          "key": "kb_id",
          "label": "Kb Id",
          "type": "text",
          "required": false
        }
      ]
    },
    {
      "id": "list_boards",
      "name": "List Boards",
      "description": "List all boards via paginated boards query.",
      "method": "GET",
      "params": [
        {
          "key": "limit",
          "label": "Limit",
          "type": "number",
          "required": false
        }
      ]
    },
    {
      "id": "get_board",
      "name": "Get Board",
      "description": "Fetch a single board by ID with items and column values.",
      "method": "GET",
      "params": [
        {
          "key": "board_id",
          "label": "Board Id",
          "type": "text",
          "required": true
        }
      ]
    },
    {
      "id": "list_items",
      "name": "List Items",
      "description": "List all items from a board via cursor-based pagination.",
      "method": "GET",
      "params": [
        {
          "key": "board_id",
          "label": "Board Id",
          "type": "text",
          "required": true
        },
        {
          "key": "limit",
          "label": "Limit",
          "type": "number",
          "required": false
        }
      ]
    },
    {
      "id": "get_item",
      "name": "Get Item",
      "description": "Fetch a single item by ID with column values.",
      "method": "GET",
      "params": [
        {
          "key": "item_id",
          "label": "Item Id",
          "type": "text",
          "required": true
        }
      ]
    },
    {
      "id": "list_workspaces",
      "name": "List Workspaces",
      "description": "List all workspaces with id and name.",
      "method": "GET",
      "params": []
    }
  ],
  "service": "monday"
}