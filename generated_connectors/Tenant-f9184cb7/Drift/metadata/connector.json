{
  "connector_type": "drift",
  "display_name": "Drift",
  "provider": "drift",
  "service": "drift",
  "auth_type": "oauth2",
  "version": "1.0.0",
  "install_fields": [
    {
      "key": "client_id",
      "label": "Client ID",
      "type": "string",
      "required": true,
      "help": "Client ID."
    },
    {
      "key": "client_secret",
      "label": "Client Secret",
      "type": "password",
      "required": true,
      "help": "Client Secret."
    },
    {
      "key": "redirect_uri",
      "label": "Redirect URI",
      "type": "string",
      "required": false,
      "help": "OAuth callback URL. Leave blank to use the default."
    }
  ],
  "scopes": [
    "conversation_read",
    "contact_read"
  ],
  "capabilities": [
    "sync",
    "health_check",
    "oauth2"
  ],
  "oauth": {
    "authorization_url": "https://dev.drift.com/authorize",
    "token_url": "https://driftapi.com/auth/token",
    "scopes": [
      "conversation_read",
      "contact_read"
    ]
  },
  "resources": [
    "conversations",
    "contacts",
    "accounts",
    "messages"
  ],
  "api_base": "https://driftapi.com",
  "apis": [
    {
      "id": "sync",
      "name": "Sync",
      "description": "Sync conversations, contacts, accounts, and messages from Drift.",
      "method": "GET",
      "params": [
        {
          "key": "full",
          "label": "Full",
          "type": "boolean",
          "required": false
        },
        {
          "key": "kb_id",
          "label": "Kb Id",
          "type": "text",
          "required": false
        }
      ]
    },
    {
      "id": "list_conversations",
      "name": "List Conversations",
      "description": "Return a paginated list of Drift conversations.",
      "method": "GET",
      "params": [
        {
          "key": "limit",
          "label": "Limit",
          "type": "number",
          "required": false
        },
        {
          "key": "next_page_token",
          "label": "Next Page Token",
          "type": "text",
          "required": false
        }
      ]
    },
    {
      "id": "get_conversation",
      "name": "Get Conversation",
      "description": "Return a single conversation by ID.",
      "method": "GET",
      "params": [
        {
          "key": "conversation_id",
          "label": "Conversation Id",
          "type": "number",
          "required": true
        }
      ]
    },
    {
      "id": "get_conversation_messages",
      "name": "Get Conversation Messages",
      "description": "Return all messages for a conversation.",
      "method": "GET",
      "params": [
        {
          "key": "conversation_id",
          "label": "Conversation Id",
          "type": "number",
          "required": true
        }
      ]
    },
    {
      "id": "list_contacts",
      "name": "List Contacts",
      "description": "Return a paginated list of Drift contacts.",
      "method": "GET",
      "params": [
        {
          "key": "limit",
          "label": "Limit",
          "type": "number",
          "required": false
        },
        {
          "key": "next_page_token",
          "label": "Next Page Token",
          "type": "text",
          "required": false
        }
      ]
    },
    {
      "id": "list_accounts",
      "name": "List Accounts",
      "description": "Return all Drift accounts.",
      "method": "GET",
      "params": []
    }
  ],
  "name": "DriftConnector",
  "description": "Shielva connector for Drift."
}