          "label": "Full",
          "type": "boolean",
          "required": false
        },
        {
          "key": "since",
          "label": "Since",
          "type": "text",
          "required": false
        },
        {
          "key": "kb_id",
          "label": "Kb Id",
          "type": "text",
          "required": false
        }
      ]
    },
    {
