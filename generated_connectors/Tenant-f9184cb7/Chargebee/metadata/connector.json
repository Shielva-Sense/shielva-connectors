{
  "connector_type": "chargebee",
  "name": "Chargebee",
  "display_name": "Chargebee",
  "description": "Connect to Chargebee to sync subscriptions, customers, and invoices from your billing account.",
  "version": "1.0.0",
  "auth_type": "api_key",
  "install_fields": [
    {
      "key": "site",
      "label": "Site",
      "type": "string",
      "required": true,
      "description": "Your Chargebee site name (e.g. 'acme' from acme.chargebee.com).",
      "help": "Site."
    },
    {
      "key": "api_key",
      "label": "API Key",
      "type": "password",
      "required": true,
      "description": "Your Chargebee API key from Settings \u2192 Configure Chargebee \u2192 API Keys.",
      "help": "API Key."
    }
  ],
  "capabilities": [
    "list_subscriptions",
    "get_subscription",
    "list_customers",
    "get_customer",
    "list_invoices",
    "get_invoice",
    "sync"
  ],
  "provider": "chargebee",
  "service": "chargebee",
  "category": "billing",
  "apis": [
    {
      "id": "sync",
      "name": "Sync",
      "description": "Sync subscriptions, customers, and invoices from Chargebee.",
      "method": "GET",
      "params": [
        {
          "key": "full",
          "label": "Full",
          "type": "boolean",
          "required": false
        },
        {
          "key": "kb_id",
          "label": "Kb Id",
          "type": "text",
          "required": false
        }
      ]
    },
    {
      "id": "list_subscriptions",
      "name": "List Subscriptions",
      "description": "Return one page of subscriptions; empty ``list`` key signals end of pagination.",
      "method": "GET",
      "params": [
        {
          "key": "limit",
          "label": "Limit",
          "type": "number",
          "required": false
        },
        {
          "key": "offset",
          "label": "Offset",
          "type": "text",
          "required": false
        }
      ]
    },
    {
      "id": "get_subscription",
      "name": "Get Subscription",
      "description": "Return a single subscription by ID (unwraps the Chargebee envelope).",
      "method": "GET",
      "params": [
        {
          "key": "subscription_id",
          "label": "Subscription Id",
          "type": "text",
          "required": true
        }
      ]
    },
    {
      "id": "list_customers",
      "name": "List Customers",
      "description": "Return one page of customers; empty ``list`` key signals end of pagination.",
      "method": "GET",
      "params": [
        {
          "key": "limit",
          "label": "Limit",
          "type": "number",
          "required": false
        },
        {
          "key": "offset",
          "label": "Offset",
          "type": "text",
          "required": false
        }
      ]
    },
    {
      "id": "get_customer",
      "name": "Get Customer",
      "description": "Return a single customer by ID (unwraps the Chargebee envelope).",
      "method": "GET",
      "params": [
        {
          "key": "customer_id",
          "label": "Customer Id",
          "type": "text",
          "required": true
        }
      ]
    },
    {
      "id": "list_invoices",
      "name": "List Invoices",
      "description": "Return one page of invoices; empty ``list`` key signals end of pagination.",
      "method": "GET",
      "params": [
        {
          "key": "limit",
          "label": "Limit",
          "type": "number",
          "required": false
        },
        {
          "key": "offset",
          "label": "Offset",
          "type": "text",
          "required": false
        }
      ]
    },
    {
      "id": "get_invoice",
      "name": "Get Invoice",
      "description": "Return a single invoice by ID (unwraps the Chargebee envelope).",
      "method": "GET",
      "params": [
        {
          "key": "invoice_id",
          "label": "Invoice Id",
          "type": "text",
          "required": true
        }
      ]
    }
  ]
}