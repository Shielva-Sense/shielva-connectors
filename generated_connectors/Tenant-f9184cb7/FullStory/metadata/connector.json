{
  "connector_type": "fullstory",
  "display_name": "FullStory",
  "provider": "FullStory",
  "service": "FullStory",
  "auth_type": "api_key",
  "version": "1.0.0",
  "description": "FullStory digital experience analytics \u2014 sync session recordings, users, and segments via the FullStory REST API v2.",
  "install_fields": [
    {
      "key": "api_key",
      "label": "API Key",
      "type": "password",
      "required": true,
      "help": "Found in FullStory Settings \u2192 Integrations \u2192 API Keys. Pass as Bearer token."
    }
  ],
  "capabilities": [
    "sync",
    "health_check"
  ],
  "resources": [
    "sessions",
    "users",
    "segments",
    "events"
  ],
  "api_base": "https://api.fullstory.com",
  "docs_url": "https://developer.fullstory.com/",
  "rate_limits": {
    "note": "FullStory enforces per-organization rate limits on REST API v2 calls. The connector respects 429 responses and retries with exponential backoff."
  },
  "apis": [
    {
      "id": "sync",
      "name": "Sync",
      "description": "Sync users and segments from FullStory.",
      "method": "GET",
      "params": [
        {
          "key": "full",
          "label": "Full",
          "type": "boolean",
          "required": false
        },
        {
          "key": "since",
          "label": "Since",
          "type": "text",
          "required": false
        },
        {
          "key": "kb_id",
          "label": "Kb Id",
          "type": "text",
          "required": false
        }
      ]
    },
    {
      "id": "list_users",
      "name": "List Users",
      "description": "List FullStory users (paginated).",
      "method": "GET",
      "params": [
        {
          "key": "limit",
          "label": "Limit",
          "type": "number",
          "required": false
        },
        {
          "key": "cursor",
          "label": "Cursor",
          "type": "text",
          "required": false
        }
      ]
    },
    {
      "id": "get_user",
      "name": "Get User",
      "description": "Retrieve a single FullStory user by UID.",
      "method": "GET",
      "params": [
        {
          "key": "uid",
          "label": "Uid",
          "type": "text",
          "required": true
        }
      ]
    },
    {
      "id": "list_sessions",
      "name": "List Sessions",
      "description": "List FullStory session recordings (optionally filtered by user UID).",
      "method": "GET",
      "params": [
        {
          "key": "uid",
          "label": "Uid",
          "type": "text",
          "required": false
        },
        {
          "key": "limit",
          "label": "Limit",
          "type": "number",
          "required": false
        },
        {
          "key": "cursor",
          "label": "Cursor",
          "type": "text",
          "required": false
        }
      ]
    },
    {
      "id": "get_session",
      "name": "Get Session",
      "description": "Retrieve a single FullStory session recording by ID.",
      "method": "GET",
      "params": [
        {
          "key": "session_id",
          "label": "Session Id",
          "type": "text",
          "required": true
        }
      ]
    },
    {
      "id": "list_segments",
      "name": "List Segments",
      "description": "List all FullStory user segments.",
      "method": "GET",
      "params": [
        {
          "key": "limit",
          "label": "Limit",
          "type": "number",
          "required": false
        }
      ]
    },
    {
      "id": "list_events",
      "name": "List Events",
      "description": "List custom events for a specific FullStory user.",
      "method": "GET",
      "params": [
        {
          "key": "uid",
          "label": "Uid",
          "type": "text",
          "required": true
        },
        {
          "key": "limit",
          "label": "Limit",
          "type": "number",
          "required": false
        }
      ]
    }
  ],
  "name": "FullStoryConnector"
}