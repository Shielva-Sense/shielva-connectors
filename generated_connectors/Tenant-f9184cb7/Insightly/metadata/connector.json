      "method": "POST",
      "params": [
        { "key": "project_name", "type": "string", "required": true },
        { "key": "status", "type": "string", "required": false }
      ],
      "returns": "Dict"
    },
    {
      "id": "update_project",
      "name": "Update Project",
      "description": "PUT /Projects/{id}.",
      "method": "PUT",
      "params": [
        { "key": "project_id", "type": "number", "required": true },
        { "key": "fields", "type": "object", "required": true }
      ],
