{
  "connector_type": "confluence",
  "display_name": "Confluence",
  "auth_type": "api_key",
  "version": "1.0.0",
  "provider": "Atlassian",
  "service": "Confluence",
  "description": "Sync Confluence spaces, pages, and blog posts into the Shielva knowledge base using the Confluence REST API v2.",
  "install_fields": [
    {
      "key": "email",
      "label": "Atlassian Account Email",
      "type": "string",
      "required": true,
      "placeholder": "you@yourcompany.com",
      "help": "The email address associated with your Atlassian account."
    },
    {
      "key": "api_token",
      "label": "API Token",
      "type": "password",
      "required": true,
      "placeholder": "ATATT3xFfGF0...",
      "help": "Atlassian API token from id.atlassian.com/manage-profile/security/api-tokens."
    },
    {
      "key": "domain",
      "label": "Confluence Domain (e.g. company.atlassian.net)",
      "type": "string",
      "required": true,
      "placeholder": "yourcompany.atlassian.net",
      "help": "Your Confluence Cloud domain. Enter only the subdomain (e.g. 'yourcompany' from 'yourcompany.atlassian.net')."
    }
  ],
  "features": [
    "retry",
    "cursor_pagination",
    "normalizer",
    "rate_limiting",
    "error_handling",
    "html_stripping"
  ],
  "methods": [
    {
      "id": "install",
      "name": "Install / Authenticate",
      "description": "Validate email + api_token + domain by calling GET /wiki/rest/api/user/current.",
      "category": "auth"
    },
    {
      "id": "health_check",
      "name": "Health Check",
      "description": "Ping GET /wiki/rest/api/user/current and return HEALTHY, DEGRADED, or OFFLINE.",
      "category": "health"
    },
    {
      "id": "sync",
      "name": "Sync Content",
      "description": "Full sync of all Confluence spaces, pages, and blog posts into the knowledge base.",
      "category": "sync"
    },
    {
      "id": "list_spaces",
      "name": "List Spaces",
      "description": "Return the first page of Confluence spaces, optionally filtered by type.",
      "category": "spaces",
      "endpoint": "GET /wiki/api/v2/spaces"
    },
    {
      "id": "get_space",
      "name": "Get Space",
      "description": "Retrieve a single Confluence space by ID.",
      "category": "spaces",
      "endpoint": "GET /wiki/api/v2/spaces/{space_id}"
    },
    {
      "id": "list_pages",
      "name": "List Pages",
      "description": "Return pages, optionally filtered by space ID and status.",
      "category": "pages",
      "endpoint": "GET /wiki/api/v2/pages"
    },
    {
      "id": "get_page",
      "name": "Get Page",
      "description": "Retrieve a single page with full body content in storage format.",
      "category": "pages",
      "endpoint": "GET /wiki/api/v2/pages/{page_id}?body-format=storage"
    },
    {
      "id": "get_page_children",
      "name": "Get Page Children",
      "description": "Retrieve child pages of a given page.",
      "category": "pages",
      "endpoint": "GET /wiki/api/v2/pages/{page_id}/children"
    },
    {
      "id": "list_blogposts",
      "name": "List Blog Posts",
      "description": "Return blog posts, optionally filtered by space ID.",
      "category": "blog_posts",
      "endpoint": "GET /wiki/api/v2/blogposts"
    },
    {
      "id": "search_content",
      "name": "Search Content",
      "description": "CQL full-text search over all Confluence content.",
      "category": "search",
      "endpoint": "GET /wiki/rest/api/search?cql=text~\"{query}\""
    }
  ],
  "categories": [
    "auth",
    "health",
    "sync",
    "spaces",
    "pages",
    "blog_posts",
    "search"
  ],
  "apis": [
    {
      "id": "sync",
      "name": "Sync",
      "description": "Sync all Confluence spaces, pages, and blog posts.",
      "method": "GET",
      "params": [
        {
          "key": "kb_id",
          "label": "Kb Id",
          "type": "text",
          "required": false
        }
      ]
    },
    {
      "id": "list_spaces",
      "name": "List Spaces",
      "description": "GET /wiki/api/v2/spaces \u2014 return first page of spaces, optionally filtered by type.",
      "method": "GET",
      "params": [
        {
          "key": "limit",
          "label": "Limit",
          "type": "number",
          "required": false
        },
        {
          "key": "type",
          "label": "Type",
          "type": "text",
          "required": false
        }
      ]
    },
    {
      "id": "get_space",
      "name": "Get Space",
      "description": "GET /wiki/api/v2/spaces/{space_id} \u2014 single space by ID.",
      "method": "GET",
      "params": [
        {
          "key": "space_id",
          "label": "Space Id",
          "type": "text",
          "required": true
        }
      ]
    },
    {
      "id": "list_pages",
      "name": "List Pages",
      "description": "GET /wiki/api/v2/pages \u2014 first page of pages, optionally filtered by space.",
      "method": "GET",
      "params": [
        {
          "key": "space_id",
          "label": "Space Id",
          "type": "text",
          "required": false
        },
        {
          "key": "status",
          "label": "Status",
          "type": "text",
          "required": false
        },
        {
          "key": "limit",
          "label": "Limit",
          "type": "number",
          "required": false
        }
      ]
    },
    {
      "id": "get_page",
      "name": "Get Page",
      "description": "GET /wiki/api/v2/pages/{page_id}?body-format=storage \u2014 single page with body.",
      "method": "GET",
      "params": [
        {
          "key": "page_id",
          "label": "Page Id",
          "type": "text",
          "required": true
        }
      ]
    },
    {
      "id": "get_page_children",
      "name": "Get Page Children",
      "description": "GET /wiki/api/v2/pages/{page_id}/children \u2014 child pages of a given page.",
      "method": "GET",
      "params": [
        {
          "key": "page_id",
          "label": "Page Id",
          "type": "text",
          "required": true
        },
        {
          "key": "limit",
          "label": "Limit",
          "type": "number",
          "required": false
        }
      ]
    },
    {
      "id": "list_blogposts",
      "name": "List Blogposts",
      "description": "GET /wiki/api/v2/blogposts \u2014 first page of blog posts, optionally filtered by space.",
      "method": "GET",
      "params": [
        {
          "key": "space_id",
          "label": "Space Id",
          "type": "text",
          "required": false
        },
        {
          "key": "limit",
          "label": "Limit",
          "type": "number",
          "required": false
        }
      ]
    },
    {
      "id": "list_blog_posts",
      "name": "List Blog Posts",
      "description": "Alias for list_blogposts \u2014 retained for backward compatibility.",
      "method": "GET",
      "params": [
        {
          "key": "space_id",
          "label": "Space Id",
          "type": "text",
          "required": false
        },
        {
          "key": "limit",
          "label": "Limit",
          "type": "number",
          "required": false
        }
      ]
    },
    {
      "id": "search_content",
      "name": "Search Content",
      "description": "GET /wiki/rest/api/search?cql=text~\"{query}\" \u2014 CQL full-text search.",
      "method": "GET",
      "params": [
        {
          "key": "query",
          "label": "Query",
          "type": "text",
          "required": true
        },
        {
          "key": "limit",
          "label": "Limit",
          "type": "number",
          "required": false
        },
        {
          "key": "cursor",
          "label": "Cursor",
          "type": "text",
          "required": false
        }
      ]
    }
  ],
  "name": "ConfluenceConnector"
}