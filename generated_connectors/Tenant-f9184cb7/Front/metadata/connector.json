{
  "connector_type": "front",
  "display_name": "Front",
  "provider": "front",
  "service": "front",
  "auth_type": "api_key",
  "version": "1.0.0",
  "description": "Connect to Front to sync conversations, contacts, teammates, inboxes, and tags.",
  "install_fields": [
    {
      "key": "api_token",
      "label": "API Token",
      "type": "password",
      "required": true,
      "description": "Your Front API token from Settings → Developers → API Tokens."
    }
  ],
  "capabilities": [
    "sync",
    "health_check",
    "list_conversations",
    "get_conversation",
    "list_messages",
    "list_contacts",
    "list_teammates",
    "list_inboxes",
    "list_tags"
  ],
  "category": "customer_support"
}
