{
  "connector_type": "planetscale",
  "name": "PlanetScaleConnector",
  "display_name": "PlanetScale",
  "version": "1.0.0",
  "description": "Connects to the PlanetScale (serverless MySQL) REST API to manage organizations, databases, branches, deploy requests, backups, and database tokens. Auth is a service token (id:token pair) sent literally in the Authorization header — no Bearer prefix.",
  "provider": "planetscale",
  "service": "planetscale",
  "auth_type": "api_key",
  "install_fields": [
    {
      "key": "service_token_id",
      "label": "Service Token ID",
      "type": "string",
      "required": true,
      "placeholder": "abc123def456",
      "help": "From PlanetScale → Settings → Service tokens → Token ID. Sent as the left half of the Authorization header."
    },
    {
      "key": "service_token",
      "label": "Service Token",
      "type": "secret",
      "required": true,
      "placeholder": "pscale_tkn_…",
      "help": "Service token secret value. PlanetScale shows this exactly once at creation — rotate if lost. Sent as the right half of the Authorization header."
    },
    {
      "key": "default_organization",
      "label": "Default Organization",
      "type": "string",
      "required": false,
      "default": "",
      "placeholder": "my-org",
      "help": "Optional default organization slug used when an API call omits 'organization'."
    },
    {
      "key": "default_database",
      "label": "Default Database",
      "type": "string",
      "required": false,
      "default": "",
      "placeholder": "my-db",
      "help": "Optional default database name used when an API call omits 'database'."
    },
    {
      "key": "base_url",
      "label": "PlanetScale API Base URL",
      "type": "string",
      "required": false,
      "default": "https://api.planetscale.com/v1",
      "placeholder": "https://api.planetscale.com/v1",
      "help": "Base URL for the PlanetScale REST API. Leave blank to use the default."
    },
    {
      "key": "rate_limit_per_min",
      "label": "Rate Limit (requests/min)",
      "type": "number",
      "required": false,
      "default": "100",
      "placeholder": "100",
      "help": "Maximum PlanetScale API requests per minute. Default is 100."
    }
  ],
  "apis": [
    {
      "id": "install",
      "name": "Install Connector",
      "description": "Validates service_token_id and service_token and marks the connector installed.",
      "method": "INTERNAL",
      "params": [],
      "returns": "ConnectorStatus"
    },
    {
      "id": "authorize",
      "name": "Authorize (Service Token)",
      "description": "Service-token auth — persists '<id>:<token>' as a synthetic TokenInfo. No OAuth exchange.",
      "method": "POST",
      "params": [
        { "key": "auth_code", "type": "string", "required": false },
        { "key": "state", "type": "string", "required": false }
      ],
      "returns": "TokenInfo"
    },
    {
      "id": "health_check",
      "name": "Health Check",
      "description": "Verifies PlanetScale API connectivity by listing one organization page.",
      "method": "GET",
      "params": [],
      "returns": "ConnectorStatus"
    },
    {
      "id": "sync",
      "name": "Sync Databases",
      "description": "Syncs PlanetScale databases (per org) into the Shielva knowledge base as NormalizedDocuments.",
      "method": "GET",
      "params": [
        { "key": "since", "type": "string", "required": false },
        { "key": "full", "type": "boolean", "required": false },
        { "key": "kb_id", "type": "string", "required": false },
        { "key": "webhook_url", "type": "string", "required": false }
      ],
      "returns": "SyncResult"
    },
    {
      "id": "list_organizations",
      "name": "List Organizations",
      "description": "GET /organizations.",
      "method": "GET",
      "params": [
        { "key": "page", "type": "number", "required": false },
        { "key": "per_page", "type": "number", "required": false }
      ],
      "returns": "Dict"
    },
    {
      "id": "get_organization",
      "name": "Get Organization",
      "description": "GET /organizations/{name}.",
      "method": "GET",
      "params": [
        { "key": "name", "type": "string", "required": true }
      ],
      "returns": "Dict"
    },
    {
      "id": "list_databases",
      "name": "List Databases",
      "description": "GET /organizations/{org}/databases.",
      "method": "GET",
      "params": [
        { "key": "organization", "type": "string", "required": false },
        { "key": "page", "type": "number", "required": false },
        { "key": "per_page", "type": "number", "required": false }
      ],
      "returns": "Dict"
    },
    {
      "id": "get_database",
      "name": "Get Database",
      "description": "GET /organizations/{org}/databases/{name}.",
      "method": "GET",
      "params": [
        { "key": "organization", "type": "string", "required": false },
        { "key": "name", "type": "string", "required": true }
      ],
      "returns": "Dict"
    },
    {
      "id": "create_database",
      "name": "Create Database",
      "description": "POST /organizations/{org}/databases.",
      "method": "POST",
      "params": [
        { "key": "organization", "type": "string", "required": false },
        { "key": "name", "type": "string", "required": true },
        { "key": "plan", "type": "string", "required": false },
        { "key": "cluster_size", "type": "string", "required": false },
        { "key": "region", "type": "object", "required": false }
      ],
      "returns": "Dict"
    },
    {
      "id": "delete_database",
      "name": "Delete Database",
      "description": "DELETE /organizations/{org}/databases/{name}.",
      "method": "DELETE",
      "params": [
        { "key": "organization", "type": "string", "required": false },
        { "key": "name", "type": "string", "required": true }
      ],
      "returns": "Dict"
    },
    {
      "id": "list_branches",
      "name": "List Branches",
      "description": "GET /organizations/{org}/databases/{db}/branches.",
      "method": "GET",
      "params": [
        { "key": "organization", "type": "string", "required": false },
        { "key": "database", "type": "string", "required": false },
        { "key": "page", "type": "number", "required": false },
        { "key": "per_page", "type": "number", "required": false }
      ],
      "returns": "Dict"
    },
    {
      "id": "get_branch",
      "name": "Get Branch",
      "description": "GET /organizations/{org}/databases/{db}/branches/{name}.",
      "method": "GET",
      "params": [
        { "key": "organization", "type": "string", "required": false },
        { "key": "database", "type": "string", "required": false },
        { "key": "name", "type": "string", "required": true }
      ],
      "returns": "Dict"
    },
    {
      "id": "create_branch",
      "name": "Create Branch",
      "description": "POST /organizations/{org}/databases/{db}/branches.",
      "method": "POST",
      "params": [
        { "key": "organization", "type": "string", "required": false },
        { "key": "database", "type": "string", "required": false },
        { "key": "name", "type": "string", "required": true },
        { "key": "parent_branch", "type": "string", "required": false },
        { "key": "backup_id", "type": "string", "required": false }
      ],
      "returns": "Dict"
    },
    {
      "id": "delete_branch",
      "name": "Delete Branch",
      "description": "DELETE /organizations/{org}/databases/{db}/branches/{name}.",
      "method": "DELETE",
      "params": [
        { "key": "organization", "type": "string", "required": false },
        { "key": "database", "type": "string", "required": false },
        { "key": "name", "type": "string", "required": true }
      ],
      "returns": "Dict"
    },
    {
      "id": "list_deploy_requests",
      "name": "List Deploy Requests",
      "description": "GET /organizations/{org}/databases/{db}/deploy-requests.",
      "method": "GET",
      "params": [
        { "key": "organization", "type": "string", "required": false },
        { "key": "database", "type": "string", "required": false },
        { "key": "state", "type": "string", "required": false },
        { "key": "page", "type": "number", "required": false }
      ],
      "returns": "Dict"
    },
    {
      "id": "get_deploy_request",
      "name": "Get Deploy Request",
      "description": "GET /organizations/{org}/databases/{db}/deploy-requests/{n}.",
      "method": "GET",
      "params": [
        { "key": "organization", "type": "string", "required": false },
        { "key": "database", "type": "string", "required": false },
        { "key": "number", "type": "number", "required": true }
      ],
      "returns": "Dict"
    },
    {
      "id": "create_deploy_request",
      "name": "Create Deploy Request",
      "description": "POST /organizations/{org}/databases/{db}/deploy-requests.",
      "method": "POST",
      "params": [
        { "key": "organization", "type": "string", "required": false },
        { "key": "database", "type": "string", "required": false },
        { "key": "branch", "type": "string", "required": true },
        { "key": "into_branch", "type": "string", "required": false },
        { "key": "notes", "type": "string", "required": false }
      ],
      "returns": "Dict"
    },
    {
      "id": "list_backups",
      "name": "List Backups",
      "description": "GET /organizations/{org}/databases/{db}/branches/{br}/backups.",
      "method": "GET",
      "params": [
        { "key": "organization", "type": "string", "required": false },
        { "key": "database", "type": "string", "required": false },
        { "key": "branch", "type": "string", "required": true },
        { "key": "page", "type": "number", "required": false },
        { "key": "per_page", "type": "number", "required": false }
      ],
      "returns": "Dict"
    },
    {
      "id": "list_database_tokens",
      "name": "List Database Tokens",
      "description": "GET /organizations/{org}/databases/{db}/branches/{br}/passwords — PlanetScale's 'database tokens' surface.",
      "method": "GET",
      "params": [
        { "key": "organization", "type": "string", "required": false },
        { "key": "database", "type": "string", "required": false },
        { "key": "branch", "type": "string", "required": true },
        { "key": "page", "type": "number", "required": false },
        { "key": "per_page", "type": "number", "required": false }
      ],
      "returns": "Dict"
    }
  ],
  "dependencies": [
    "httpx>=0.27.0",
    "tenacity>=8.2"
  ]
}
