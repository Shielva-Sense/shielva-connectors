{
  "connector_type": "powerbi",
  "display_name": "Power BI",
  "provider": "Microsoft",
  "service": "Power BI",
  "auth_type": "oauth2",
  "version": "1.0.0",
  "description": "Sync Microsoft Power BI dashboards, reports, and datasets into the Shielva knowledge base via the Power BI REST API v1.0.",
  "install_fields": [
    {
      "key": "client_id",
      "label": "Application (client) ID",
      "type": "string",
      "required": true,
      "placeholder": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx",
      "help": "From Azure Portal → App registrations → your app → Overview → Application (client) ID"
    },
    {
      "key": "client_secret",
      "label": "Client Secret",
      "type": "password",
      "required": true,
      "placeholder": "Client secret value",
      "help": "From Azure Portal → App registrations → your app → Certificates & secrets → Client secrets"
    },
    {
      "key": "tenant_id_azure",
      "label": "Azure Tenant ID",
      "type": "string",
      "required": true,
      "placeholder": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx",
      "help": "From Azure Portal → Azure Active Directory → Overview → Tenant ID"
    }
  ],
  "scopes": [
    "https://analysis.windows.net/powerbi/api/.default",
    "offline_access"
  ],
  "oauth_auth_url_template": "https://login.microsoftonline.com/{tenant_id_azure}/oauth2/v2.0/authorize",
  "oauth_token_url_template": "https://login.microsoftonline.com/{tenant_id_azure}/oauth2/v2.0/token",
  "api_base": "https://api.powerbi.com/v1.0/myorg/",
  "capabilities": ["sync", "health_check", "oauth2"],
  "entities": ["dashboards", "reports", "datasets", "workspaces"],
  "methods": [
    {"id": "install", "name": "Install / Authenticate", "category": "auth"},
    {"id": "authorize", "name": "Get OAuth URL", "category": "auth"},
    {"id": "health_check", "name": "Health Check", "category": "health"},
    {"id": "sync", "name": "Sync Power BI Resources", "category": "sync"},
    {"id": "list_dashboards", "name": "List Dashboards", "category": "dashboards"},
    {"id": "list_reports", "name": "List Reports", "category": "reports"},
    {"id": "list_datasets", "name": "List Datasets", "category": "datasets"},
    {"id": "list_workspaces", "name": "List Workspaces", "category": "workspaces"}
  ]
}
