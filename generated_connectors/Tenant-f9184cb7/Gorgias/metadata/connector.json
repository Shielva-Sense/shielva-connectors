{
  "connector_type": "gorgias",
  "display_name": "Gorgias",
  "provider": "gorgias",
  "service": "gorgias",
  "auth_type": "api_key",
  "version": "1.0.0",
  "description": "Sync Gorgias eCommerce customer support tickets, customers, tags, macros, and satisfaction surveys.",
  "install_fields": [
    {
      "key": "account",
      "label": "Gorgias Account (subdomain)",
      "type": "string",
      "required": true,
      "placeholder": "mystore",
      "help": "Your Gorgias subdomain \u2014 the part before .gorgias.com (e.g. mystore)."
    },
    {
      "key": "email",
      "label": "Email",
      "type": "string",
      "required": true,
      "placeholder": "support@mystore.com",
      "help": "The email address associated with your Gorgias account."
    },
    {
      "key": "api_key",
      "label": "API Key",
      "type": "password",
      "required": true,
      "placeholder": "\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022",
      "help": "Generate an API key in Gorgias \u2192 Settings \u2192 REST API."
    }
  ],
  "resources": [
    "tickets",
    "customers",
    "tags",
    "macros",
    "satisfaction_surveys"
  ],
  "capabilities": [
    "sync",
    "health_check"
  ],
  "auth_details": {
    "method": "Basic",
    "header": "Authorization",
    "format": "Basic base64(email:api_key)",
    "notes": "Gorgias uses standard HTTP Basic Auth. Username = email, Password = API key."
  },
  "api_base": "https://{account}.gorgias.com/api/",
  "pagination": {
    "strategy": "cursor",
    "cursor_field": "meta.next_cursor",
    "default_page_size": 100
  },
  "rate_limits": {
    "requests_per_second": 2,
    "retry_on_429": true,
    "respect_retry_after_header": true
  },
  "apis": [
    {
      "id": "sync",
      "name": "Sync",
      "description": "Sync all Gorgias resources into the knowledge base.",
      "method": "GET",
      "params": [
        {
          "key": "full",
          "label": "Full",
          "type": "boolean",
          "required": false
        },
        {
          "key": "since",
          "label": "Since",
          "type": "text",
          "required": false
        },
        {
          "key": "kb_id",
          "label": "Kb Id",
          "type": "text",
          "required": false
        }
      ]
    },
    {
      "id": "list_tickets",
      "name": "List Tickets",
      "description": "Return a list of Gorgias tickets (one page).",
      "method": "GET",
      "params": [
        {
          "key": "page",
          "label": "Page",
          "type": "number",
          "required": false
        },
        {
          "key": "limit",
          "label": "Limit",
          "type": "number",
          "required": false
        },
        {
          "key": "cursor",
          "label": "Cursor",
          "type": "text",
          "required": false
        }
      ]
    },
    {
      "id": "get_ticket",
      "name": "Get Ticket",
      "description": "Return a single Gorgias ticket by ID.",
      "method": "GET",
      "params": [
        {
          "key": "ticket_id",
          "label": "Ticket Id",
          "type": "number",
          "required": true
        }
      ]
    },
    {
      "id": "list_customers",
      "name": "List Customers",
      "description": "Return a list of Gorgias customers (one page).",
      "method": "GET",
      "params": [
        {
          "key": "page",
          "label": "Page",
          "type": "number",
          "required": false
        },
        {
          "key": "limit",
          "label": "Limit",
          "type": "number",
          "required": false
        },
        {
          "key": "cursor",
          "label": "Cursor",
          "type": "text",
          "required": false
        }
      ]
    },
    {
      "id": "get_customer",
      "name": "Get Customer",
      "description": "Return a single Gorgias customer by ID.",
      "method": "GET",
      "params": [
        {
          "key": "customer_id",
          "label": "Customer Id",
          "type": "number",
          "required": true
        }
      ]
    },
    {
      "id": "list_tags",
      "name": "List Tags",
      "description": "Return all Gorgias tags.",
      "method": "GET",
      "params": []
    },
    {
      "id": "list_macros",
      "name": "List Macros",
      "description": "Return a list of Gorgias macros (one page).",
      "method": "GET",
      "params": [
        {
          "key": "page",
          "label": "Page",
          "type": "number",
          "required": false
        },
        {
          "key": "limit",
          "label": "Limit",
          "type": "number",
          "required": false
        },
        {
          "key": "cursor",
          "label": "Cursor",
          "type": "text",
          "required": false
        }
      ]
    }
  ],
  "name": "GorgiasConnector"
}